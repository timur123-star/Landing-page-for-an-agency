# Resend API key — https://resend.com/api-keys
# When unset, the contact form still works but only logs the payload (200 with delivered:false)
RESEND_API_KEY=

# Where to deliver new contact-form submissions
CONTACT_INBOX=hello@nova-agency.studio

# Verified sender for Resend (use the default sandbox if you haven't set up a domain yet)
RESEND_FROM="NOVA Studio <onboarding@resend.dev>"
